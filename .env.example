# Example .env file for RobotJudge-CI
# Copy this file to .env and fill in the values before running docker-compose

# Ngrok token for exposing the web server publicly.
# Get this from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# PostgreSQL database credentials
POSTGRES_USER=rj
POSTGRES_PASSWORD=rj
POSTGRES_DB=robotjudge
