{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/robotjudge/schemas/case.schema.json",
  "title": "RobotJudge GridPath Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "grid",
    "start",
    "goal",
    "moves"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "moves": {
      "type": "string",
      "enum": [
        "4N",
        "8N"
      ]
    },
    "grid": {
      "description": "Either a 2D 0/1 matrix (0=free, 1=obstacle) OR an RLE-packed representation.",
      "oneOf": [
        {
          "$ref": "#/$defs/grid_matrix"
        },
        {
          "$ref": "#/$defs/grid_rle"
        }
      ]
    },
    "start": {
      "$ref": "#/$defs/cell"
    },
    "goal": {
      "$ref": "#/$defs/cell"
    },
    "cell_cost": {
      "description": "Optional per-cell non-negative weights. If absent/null, uniform cost is assumed.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      ]
    },
    "limits": {
      "description": "Per-run limits; judge may override with stricter CI limits.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "mem_mb": {
          "type": "integer",
          "minimum": 16,
          "maximum": 65536
        },
        "max_path_len": {
          "type": "integer",
          "minimum": 2,
          "maximum": 2000000
        }
      }
    },
    "seed_policy": {
      "description": "Default seed policy for this case; runner may override via CLI.",
      "oneOf": [
        {
          "$ref": "#/$defs/seed_range"
        },
        {
          "$ref": "#/$defs/seed_list"
        }
      ]
    },
    "meta": {
      "description": "Free-form metadata used for traceability (generator family, difficulty tag, etc.).",
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "cell": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 2000000
        },
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 2000000
        }
      ]
    },
    "grid_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        }
      }
    },
    "grid_rle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rows",
        "cols",
        "encoding",
        "data"
      ],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000000
        },
        "cols": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000000
        },
        "encoding": {
          "type": "string",
          "const": "rle01"
        },
        "data": {
          "description": "Run-length encoding of 0/1 cells row-major. Format: '0:12,1:3,0:7,...'",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "seed_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "start",
        "count"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "range"
        },
        "start": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "seed_list": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "seeds"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "list"
        },
        "seeds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000000,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647
          }
        }
      }
    }
  }
}