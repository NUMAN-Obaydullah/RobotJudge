{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/robotjudge/schemas/results.schema.json",
    "title": "RobotJudge CI Results",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "version",
        "run_id",
        "suite_id",
        "submission",
        "seed_policy",
        "runs",
        "per_case",
        "suite"
    ],
    "properties": {
        "version": {
            "type": "string",
            "const": "1.0"
        },
        "run_id": {
            "type": "string",
            "minLength": 6,
            "maxLength": 128
        },
        "suite_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
        },
        "submission": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "entrypoint"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                },
                "entrypoint": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                },
                "commit": {
                    "type": "string",
                    "minLength": 7,
                    "maxLength": 64
                },
                "environment": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                }
            }
        },
        "seed_policy": {
            "oneOf": [
                {
                    "$ref": "#/$defs/seed_range"
                },
                {
                    "$ref": "#/$defs/seed_list"
                }
            ]
        },
        "runs": {
            "description": "Per testcase × per seed records.",
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/run_record"
            }
        },
        "per_case": {
            "description": "Aggregated robustness metrics per testcase.",
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/case_aggregate"
            }
        },
        "suite": {
            "description": "Whole-suite aggregation and gate decisions.",
            "type": "object",
            "additionalProperties": false,
            "required": [
                "status",
                "suite_success_rate",
                "suite_score",
                "p95_runtime_ms"
            ],
            "properties": {
                "status": {
                    "type": "string",
                    "enum": [
                        "PASS",
                        "FAIL"
                    ]
                },
                "suite_success_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "suite_score": {
                    "type": "number"
                },
                "p95_runtime_ms": {
                    "type": "integer",
                    "minimum": 0
                },
                "notes": {
                    "type": "string"
                }
            }
        }
    },
    "$defs": {
        "seed_range": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "type",
                "start",
                "count"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "const": "range"
                },
                "start": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2147483647
                },
                "count": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000000
                }
            }
        },
        "seed_list": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "type",
                "seeds"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "const": "list"
                },
                "seeds": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1000000,
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 2147483647
                    }
                }
            }
        },
        "run_record": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "case_id",
                "seed",
                "status",
                "valid",
                "runtime_ms"
            ],
            "properties": {
                "case_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                },
                "seed": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 2147483647
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "AC",
                        "WA",
                        "TLE",
                        "MLE",
                        "RTE"
                    ]
                },
                "valid": {
                    "type": "boolean"
                },
                "collision": {
                    "type": "boolean"
                },
                "reached_goal": {
                    "type": "boolean"
                },
                "cost": {
                    "type": "number",
                    "minimum": 0
                },
                "path_length": {
                    "type": "number",
                    "minimum": 0
                },
                "runtime_ms": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 600000
                },
                "mem_mb": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 65536
                },
                "violations": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 256
                    }
                },
                "stdout_path": {
                    "type": "string"
                },
                "stderr_path": {
                    "type": "string"
                }
            }
        },
        "case_aggregate": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "case_id",
                "success_rate",
                "failure_rate",
                "best_cost",
                "mean_cost",
                "p95_cost",
                "p95_runtime_ms"
            ],
            "properties": {
                "case_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                },
                "success_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "failure_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "best_cost": {
                    "type": "number",
                    "minimum": 0
                },
                "mean_cost": {
                    "type": "number",
                    "minimum": 0
                },
                "p95_cost": {
                    "type": "number",
                    "minimum": 0
                },
                "best_runtime_ms": {
                    "type": "integer",
                    "minimum": 0
                },
                "mean_runtime_ms": {
                    "type": "integer",
                    "minimum": 0
                },
                "p95_runtime_ms": {
                    "type": "integer",
                    "minimum": 0
                },
                "notes": {
                    "type": "string"
                }
            }
        }
    }
}